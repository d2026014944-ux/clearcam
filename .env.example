# ClearCAM runtime settings for free-tier deploy.
# Copy to .env and adjust values before starting the service.

# Optional: premium sync credentials.
CLEARCAM_USERID=
CLEARCAM_KEY=

# Runtime tuning for free-tier machines.
CLEARCAM_USE_CLIP=false
CLEARCAM_YOLO_SIZE=t
CLEARCAM_YOLO_RES=640

# This command does not currently expose port flags in clearcam.py.
# Keep reverse proxy pointing to localhost:8080.
CLEARCAM_BIND=0.0.0.0
CLEARCAM_PORT=8080

# Optional URL used by generated docs and proxy templates.
CLEARCAM_DOMAIN=example.com
